# ─────────────────────────────────────────────────────────────
# fanvault-frontend — Environment Configuration
# ─────────────────────────────────────────────────────────────
# This is a React/Vite SPA. All API calls use relative paths
# (e.g. /api/auth/login) which Nginx proxies to the backend.
# No backend URLs are embedded here — they live in nginx.conf.
#
# Only build-time variables (VITE_ prefix) are relevant here.
# ─────────────────────────────────────────────────────────────

# Purpose  : App name shown in the browser tab and meta tags
# Required : No
# Secret   : No
VITE_APP_NAME=FanVault
